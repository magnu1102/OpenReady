{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openready.dev/schemas/openready.pack.v1.schema.json",
  "title": "OpenReady check pack manifest (v1)",
  "description": "Metadata describing a pack of third-party custom checks. The manifest is data only; the executable checks live alongside it and run under OpenReady's explicit-trust model.",
  "type": "object",
  "required": ["schema", "name", "version", "checkIds"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "openready.pack.v1" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "checkIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*$" }
    }
  }
}
