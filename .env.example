# Optional: raises GitHub API rate limits for local CLI runs.
OPENREADY_GITHUB_TOKEN=

# Optional fallback used by the CLI when OPENREADY_GITHUB_TOKEN is unset.
# GitHub Actions sets this automatically for workflow jobs.
# GITHUB_TOKEN=

# Optional: disable colored CLI output.
# NO_COLOR=1

# Optional: expose the Vite/Tauri dev server to another host during local work.
# TAURI_DEV_HOST=
